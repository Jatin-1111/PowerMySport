x`# ── Never needed by EB ────────────────────────────────────────────────
node_modules/
dist/
coverage/
*.log
npm-debug.log*

# ── Secrets — set these as EB Environment Variables ──────────────────
.env
.env.*
*.env

# ── Local Docker / dev only — EB uses Dockerfile directly ─────────────
# Keeping docker-compose.yml out of the bundle prevents EB from switching
# to compose mode, which would require .env.docker (stripped above) and
# break the deployment. Use docker-compose locally as normal.
docker-compose.yml

# ── Dev / OS junk ─────────────────────────────────────────────────────
.DS_Store
debug_output.txt
docs/
src/**/*.test.ts
