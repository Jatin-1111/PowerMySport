model Venue {
  id                  String              @id @default(cuid())
  ownerName           String
  ownerEmail          String
  ownerPhone          String
  emailVerified       Boolean             @default(false)
  name                String
  ownerId             String?
  sports              String[]            @default([])
  pricePerHour        Int
  amenities           String[]            @default([])
  address             String              @default("")
  description         String              @default("")
  images              String[]            @default([]) // legacy
  imageKeys           String[]            @default([]) // legacy
  generalImages       String[]            @default([])
  generalImageKeys    String[]            @default([])
  coverPhotoUrl       String?
  coverPhotoKey       String?
  allowExternalCoaches Boolean            @default(true)
  approvalStatus      VenueApprovalStatus @default(PENDING)
  rejectionReason     String?
  reviewNotes         String?
  rating              Float               @default(0)
  reviewCount         Int                 @default(0)
  hasCoaches          Boolean             @default(false)
  // location GeoJSON Point -> lng/lat (required in Mongo)
  lng                 Float?
  lat                 Float?

  sportPricing   VenueSportPricing[]
  sportImages    VenueSportImage[]
  openingHours   VenueOpeningHour[]
  venueCoaches   VenueCoach[]
  documents      VenueDocument[]
  payoutMethods  VenuePayoutMethod[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId, createdAt(sort: Desc)])
  @@index([ownerEmail, approvalStatus])
  @@index([approvalStatus, createdAt(sort: Desc)])
  @@index([sports, approvalStatus])
  @@map("venues")
}

