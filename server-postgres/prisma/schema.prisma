// ============================================================================
// CLIENT DOMAIN — users, coaches, venues, bookings, wallet, experts, etc.
// ============================================================================

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  phone         String    @unique
  role          UserRole  @default(Player)
  userType      UserType  @default(Player)
  password      String? // null for Google-only accounts; bcrypt hashed in app layer
  googleId      String?   @unique
  photoUrl      String?
  photoS3Key    String?
  city          String?
  lastActiveAt  DateTime? @default(now())
  dob           DateTime?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  isActive      Boolean   @default(true)
  suspensionReason String @default("")
  suspendedAt   DateTime?
  suspendedBy   String? // -> Admin.id
  deactivatedAt DateTime?
  defaultAddressId String?

  // legal consents + notification/reminder prefs kept as structured Json config
  // (never queried relationally; read/written wholesale). See SCHEMA_CHANGES.md.
  legalConsents           Json?
  notificationPreferences Json?
  reminderPreferences     Json?
  // single shipping address (shop) — kept inline as owned 1:1
  shippingAddress Json?
  // parentProfile subdoc {bio, sportInterests[], involvementYears} (GitHub pull)
  parentProfile   Json?

  addresses         Address[]
  pushSubscriptions PushSubscription[]
  refundMethods     RefundMethod[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role, createdAt(sort: Desc)])
  @@index([role, isActive])
  @@index([lastActiveAt])
  @@index([isActive])
  @@map("users")
}

model Address {
  id           String  @id @default(cuid())
  userId       String
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName     String
  email        String
  phone        String
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  postalCode   String
  country      String  @default("IN")
  isDefault    Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@map("user_addresses")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("user_push_subscriptions")
}

model RefundMethod {
  id                String           @id @default(cuid())
  userId            String
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              RefundMethodType @default(ORIGINAL_CARD)
  accountHolderName String?
  accountNumber     String?
  ifscCode          String?
  bankName          String?
  isDefault         Boolean          @default(false)
  addedAt           DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([userId])
  @@map("user_refund_methods")
}

model Player {
  id                   String            @id @default(cuid())
  userId               String
  type                 PlayerType
  name                 String
  age                  Int?
  dob                  DateTime?
  gender               Gender?
  relation             String?
  sportsFocus          String[]          @default([])
  skillLevel           String?
  yearsPlaying         Int?
  personalityTags      String[]          @default([])
  primaryObjective     PrimaryObjective?
  weeklyTimeCommitment Int?
  budgetTier           BudgetTier?
  location             String?
  // pathwayState (single embedded obj) flattened
  psSatisfiedPrereqs   String[]          @default([])
  psCurrentGpa         Float?
  psTargetDivision     String?
  psGraduationYear     Int?

  // --- Sport-selection wizard fields (added by GitHub pull) ---
  heightCm            Int?
  weightKg            Int?
  medicalConditions   String[]          @default([])
  // wizard enums have hyphen/digit values (e.g. "3k-7k") -> stored as String
  build               String?
  heightCategory      String?
  energyType          String?
  motorType           String?
  visualTracking      String?
  teamIndividual      Int? // 1=very individual, 5=very team
  competitiveResponse String?
  focusStyle          String?
  decisionStyle       String?
  pressureResponse    String?
  repetitionTolerance String?
  contactComfort      String?
  environment         String?
  waterComfort        String?
  budgetRange         String?
  ambition            String?
  eyesight            String?
  agility             String?
  weeklyHoursCategory String?
  experienceLevel     String?
  trainingType        String?
  wizardCity          String?
  sportMatches        Json              @default("[]") // [{sport,fitLabel,score}]
  wizardCompletedAt   DateTime?

  paymentHistory PlayerPaymentHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("players")
}

model PlayerPaymentHistory {
  id        String   @id @default(cuid())
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  bookingId String?
  amount    Int?
  date      DateTime?

  @@index([playerId])
  @@map("player_payment_history")
}

model Coach {
  id                    String                         @id @default(cuid())
  userId                String                         @unique
  bio                   String                         @default("")
  certifications        String[]                       @default([])
  sports                String[]
  hourlyRate            Int
  serviceMode           ServiceMode
  serviceRadiusKm       Int?
  travelBufferTime      Int?
  rating                Float                          @default(0)
  reviewCount           Int                            @default(0)
  verificationStatus    CoachVerificationStatus        @default(UNVERIFIED)
  verificationNotes     String                         @default("")
  onboardingProgressStep Int                           @default(1)
  activeSubscriptionId  String?
  subscriptionStatus    CoachSubscriptionStatusOnCoach @default(NONE)
  subscriptionExpiresAt DateTime?
  verificationSubmittedAt     DateTime?
  lastVerificationReminderAt  DateTime?
  verifiedAt            DateTime?
  verifiedBy            String? // -> Admin.id
  isVerified            Boolean                        @default(false)

  // baseLocation GeoJSON Point -> lng/lat
  baseLng               Float?
  baseLat               Float?

  // ownVenueDetails (single embedded obj) -> owned 1:1 child
  ownVenue              CoachOwnVenue?
  sportPricing          CoachSportPricing[]
  availability          CoachAvailability[]
  sportAvailability     CoachSportAvailability[]
  documents             CoachDocument[]
  blockedDates          CoachBlockedDate[]
  payoutMethods         CoachPayoutMethod[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sports])
  @@index([serviceMode])
  @@index([isVerified])
  @@index([verificationStatus])
  @@index([subscriptionStatus])
  @@map("coaches")
}

model CoachOwnVenue {
  id           String   @id @default(cuid())
  coachId      String   @unique
  coach        Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  name         String?
  address      String?
  lng          Float?
  lat          Float?
  sports       String[] @default([])
  amenities    String[] @default([])
  pricePerHour Int?
  description  String?
  images       String[] @default([])
  imageS3Keys  String[] @default([])
  openingHours String?

  @@map("coach_own_venues")
}

model CoachSportPricing {
  id      String @id @default(cuid())
