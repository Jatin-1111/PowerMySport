  // NOTE: Postgres treats NULLs as distinct, so this unique does NOT enforce a
  // single "no-dependent" profile per user like the Mongo index did. If that
  // guarantee is required, add a partial/expression unique via raw SQL:
  //   CREATE UNIQUE INDEX user_pathway_profile_user_null_dep
  //     ON user_pathway_profiles (user_id) WHERE dependent_id IS NULL;
  @@unique([userId, dependentId])
  @@map("user_pathway_profiles")
}

// SportPathway / SportBasePath / SportStatePath store AI-generated pathway
// content documents (deeply nested, read/written as a whole). Their nested
// level/tournament/etc arrays are kept as structured Json rather than ~15
// child tables (see SCHEMA_CHANGES.md, Pathway content, for the rationale).
model SportPathway {
  id                          String    @id @default(cuid())
  sportSlug                   String
  sportName                   String
  cacheKey                    String?
  category                    String    @default("Other")
  overview                    String    @default("")
  // progressionPlan {gap,prerequisites[],milestones[],...} (GitHub pull)
  progressionPlan             Json?
  levels                      Json      @default("[]")
  tournaments                 Json      @default("[]")
  scholarships                Json      @default("[]")
  universities                Json      @default("[]")
  equipment                   Json      @default("[]")
  careers                     Json      @default("[]")
  tournamentsVerifiedEmpty    Boolean   @default(false)
  scholarshipsVerifiedEmpty   Boolean   @default(false)
  universitiesVerifiedEmpty   Boolean   @default(false)
  isVerified                  Boolean   @default(false)
  verifiedAt                  DateTime?
  verifiedBy                  String?
  lookupCount                 Int       @default(1)
  contentRefreshedAt          DateTime?
  financialDataRefreshedAt    DateTime?
  contentRefreshInProgress    Boolean   @default(false)
  financialRefreshInProgress  Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sportSlug])
  @@index([cacheKey])
  @@map("sport_pathways")
}

model SportBasePath {
  id          String   @id @default(cuid())
  sportSlug   String   @unique
  sportName   String
  category    String?
  overview    String
  levels      Json     @default("[]")
  equipment   Json     @default("[]")
  careers     Json     @default("[]")
  generatedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sport_base_paths")
}

model SportStatePath {
  id                String   @id @default(cuid())
  sportSlug         String
  stateSlug         String
  stateName         String
  saName            String?
  saAcronym         String?
  saWebsite         String?
  saContact         String?
  topAcademies      Json     @default("[]")
  feeMonthly        String?
  feeEquipment      String?
  feeTournaments    String?
  governmentSchemes Json     @default("[]")
  regionalCalendar  String
  generatedAt       DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sportSlug, stateSlug])
  @@map("sport_state_paths")
}

// ============================================================================
// NEW FEATURES (added via GitHub pull) - Federation, PlanCheckIn, Screening
// ============================================================================

// Federation is reference/content data (consumed as a whole document), so the
// nested structures are kept as Json - consistent with pathway content models.
model Federation {
  id                  String         @id @default(cuid())
  slug                String         @unique
  name                String
  acronym             String
  sportSlug           String
  type                FederationType
  about               String
  founded             Int?
  headquarters        String?
  website             String?
  officialCalendarUrl String?
  socialLinks         Json?
  affiliations        String[]       @default([])
  stateAssociations   Json           @default("[]")
  keyFacts            String[]       @default([])
  eligibilityCriteria Json?
  registrationSteps   String[]       @default([])
  requiredDocuments   String[]       @default([])
  contact             Json?
  dataVerifiedAt      DateTime?
  sourceUrls          String[]       @default([])
  isActive            Boolean        @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sportSlug])
  @@map("federations")
}

model PlanCheckIn {
  id           String            @id @default(cuid())
  userId       String
  dependentId  String?
  source       PlanCheckInSource
  sourceId     String?
  sport        String
  title        String
  signals      String[]          @default([])
  checkInDueAt DateTime
  status       PlanCheckInStatus @default(active)
  outcomeNote  String?
  respondedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([checkInDueAt])
  @@index([status])
  @@index([userId, status, createdAt(sort: Desc)])
  @@map("plan_check_ins")
}

model ScreeningRequest {
  id            String          @id @default(cuid())
  parentId      String?
  dependentName String
  sport         String?
  phone         String
  preferredTime String?
  city          String?
  status        ScreeningStatus @default(requested)
  adminNotes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@map("screening_requests")
}