// ============================================================================
// PowerMySport — PostgreSQL (Prisma) schema
// Ported from the MongoDB/Mongoose data layer (see server/src/**/models).
//
// Design rules (see prisma/SCHEMA_CHANGES.md for the full rationale):
//  * Primary keys are String and default to cuid(). Rows migrated from Mongo
//    keep their original 24-char ObjectId hex string as the id, so every
//    cross-document reference survives the ETL unchanged.
//  * Embedded *sub-document* arrays and object-maps are normalized into child
//    tables with foreign keys (e.g. Booking.payments, Coach.sportPricing).
//  * Scalar arrays of atomic values (sport slugs, tags, amenities, S3 keys)
//    are kept as native Postgres String[] — normalizing atoms into join tables
//    adds no relational value. This is the one documented deviation from
//    "every array becomes a table".
//  * GeoJSON Point { coordinates:[lng,lat] } becomes longitude/latitude Float
//    columns. Mongo $near / 2dsphere radius queries must be re-implemented with
//    PostGIS or the earthdistance module (documented as a behavioral change).
//  * Mongoose "Mixed" fields become Json.
//  * Mongo TTL indexes have no Postgres equivalent; a cron sweeper replaces them
//    (see scripts/ttlSweeper). Fields keep an expiresAt/resetAt column + index.
//  * enum fields whose values are all valid identifiers become native Prisma
//    enums; enums containing spaces, ampersands, leading digits or hyphens stay
//    String with app-layer validation (matching the old Mongoose behavior).
//  * Polymorphic references (targetType + targetId) stay as indexed String
//    columns — relational DBs cannot express a single FK to multiple tables.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

