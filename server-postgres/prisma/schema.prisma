  promoCode      String?
  discountAmount Int               @default(0)
  status         BookingStatus     @default(PENDING_CONFIRMATION)
  expiresAt      DateTime?
  checkInCode    String?
  participantName String
  participantId  String?
  participantAge Int?
  paymentConfirmedAt      DateTime?
  confirmationEmailSentAt DateTime?
  cancelledAt    DateTime?
  cancellationReason String?
  refundAmount   Int?
  refundStatus   BookingRefundStatus?
  bookingType    BookingType       @default(INDIVIDUAL)
  organizerId    String
  paymentType    BookingPaymentType @default(SINGLE)
  splitMethod    SplitMethod?

