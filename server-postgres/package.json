{
  "name": "server-postgres",
  "version": "1.0.0",
  "description": "PowerMySport API — PostgreSQL/Prisma port of the MongoDB server",
  "main": "index.js",
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "scripts": {
    "dev": "nodemon --exec \"ts-node\" src/server.ts",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && prisma generate && node ./node_modules/typescript/bin/tsc",
    "start": "node dist/server.js",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "prisma:validate": "prisma validate",
    "prisma:format": "prisma format",
    "db:seed": "ts-node prisma/seed.ts",
    "db:seed:sports": "ts-node src/scripts/seedSports.ts",
    "ttl:sweep": "ts-node src/scripts/ttlSweeper.ts",
    "etl:from-mongo": "ts-node --transpile-only prisma/migrate-from-mongo/etl.ts",
    "etl:from-mongo:fresh": "ts-node --transpile-only prisma/migrate-from-mongo/etl.ts --truncate",
    "etl:validate": "ts-node --transpile-only prisma/migrate-from-mongo/validate.ts",
    "migrate:admin-permissions": "ts-node src/scripts/migrateAdminPermissions.ts",
    "community:players-public": "ts-node src/scripts/makePlayerProfilesPublic.ts",
    "scrape:tournaments": "ts-node src/scripts/scrapeTournaments.ts",
    "scrape:scholarships": "ts-node src/scripts/scrapeScholarships.ts",
    "scrape:universities": "ts-node src/scripts/scrapeUniversities.ts",
    "purge:venues": "ts-node src/scripts/deleteAllVenueData.ts",
    "purge:smoke-users": "ts-node src/scripts/deleteSmokeUsers.ts",
    "stress:booking-race": "ts-node src/scripts/stressBookingConcurrency.ts",
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:qna": "npm run build && node --test dist/tests/communityQnaUtils.test.js",
    "test:community-policy": "npm run build && node --test dist/tests/communityPolicy.test.js",
    "test:community": "npm run build && node --test dist/tests/communityQnaUtils.test.js dist/tests/communityPolicy.test.js",
    "test:coach-subscriptions": "npm run build && node --test dist/tests/coachSubscriptionRoutes.integration.test.js",
    "test:security": "npm run build && node --test --test-force-exit dist/tests/security.unit.test.js dist/tests/security.integration.test.js",
    "test:email": "npm run build && node --test dist/tests/email.unit.test.js",
    "email:verify": "ts-node src/scripts/verifyEmail.ts",
    "email:test-all": "ts-node src/scripts/testAllEmails.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.985.0",
    "@aws-sdk/client-elastic-beanstalk": "^3.985.0",
    "@aws-sdk/client-s3": "^3.985.0",
    "@aws-sdk/s3-presigned-post": "^3.1068.0",
    "@aws-sdk/s3-request-presigner": "^3.985.0",
    "@google/genai": "^2.9.0",
    "@phonepe-pg/pg-sdk-node": "^2.0.5",
    "@prisma/client": "^5.22.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/express-rate-limit": "^5.1.3",
    "@types/nodemailer": "^7.0.9",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "axios": "^1.18.0",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.7.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.0",
    "openai": "^6.44.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pdfkit": "^0.17.1",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.1.0",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.3",
    "@types/web-push": "^3.6.4",
    "mongodb": "^7.4.0",
    "nodemon": "^3.1.11",
    "prisma": "^5.22.0",
    "supertest": "^7.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
